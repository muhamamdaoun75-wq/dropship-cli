# Dropship CLI — Environment Variables
# Copy this to .env and fill in your values

# Required — Anthropic API key (the AI brain)
ANTHROPIC_API_KEY=sk-ant-...

# Required — Shopify store credentials
SHOPIFY_SHOP=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10

# Optional — Shopify App OAuth (for `dropship connect` OAuth flow)
# Create at https://partners.shopify.com → Apps → Create app
# Set redirect URL to: http://127.0.0.1:3456/callback
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Optional — Supabase for state persistence
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Optional — CJ Dropshipping supplier integration
CJ_EMAIL=your@email.com
CJ_PASSWORD=your-password
CJ_API_KEY=
CJ_REFRESH_STRATEGY=A
CJ_AFFILIATE_ID=dropship-cli

# Optional — License key (Pro tier)
DROPSHIP_LICENSE_KEY=DSC-...

# Optional — Debug mode (verbose error output)
# DEBUG=1
