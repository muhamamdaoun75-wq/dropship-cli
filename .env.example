# Dropship CLI — Environment Variables
# Copy this to .env and fill in your values

# Required — Anthropic API key (the AI brain)
ANTHROPIC_API_KEY=sk-ant-...

# Required — Shopify store credentials
SHOPIFY_SHOP=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10

# Optional — Supabase for state persistence
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Optional — CJ Dropshipping
CJ_API_KEY=...
CJ_EMAIL=
CJ_PASSWORD=
CJ_REFRESH_STRATEGY=A

# Optional — License key (Pro tier)
DROPSHIP_LICENSE_KEY=DSC-...
